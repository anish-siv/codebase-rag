ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional. Only needed for a public deployment: when set, /api/ingest,
# /api/ingest/github, and /api/clear require an "X-Admin-Key" header
# matching this value. Leave unset for local dev (no auth enforced).
# ADMIN_KEY=

# Optional. Override the default local Postgres connection (used for a
# managed Postgres like Neon in production; see README's Deployment section).
# SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/<db>?sslmode=require
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
